# Backend API URL
# For local dev: http://localhost:5000
# For production: https://your-render-backend.onrender.com
VITE_API_URL=http://localhost:5000

# Google OAuth Client ID (same as server GOOGLE_CLIENT_ID)
# Must be set in Vercel env vars for production
# Must add the deployed URL to Google Cloud Console Authorized JavaScript origins
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
