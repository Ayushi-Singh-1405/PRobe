# Server
DATABASE_URL=postgresql://user:password@host:5432/probe
JWT_SECRET=your_super_secret_jwt_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GITHUB_TOKEN=your_optional_default_github_token

# Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
# Must be a "Web application" OAuth 2.0 Client ID
# Same ID used in client/.env as VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

PORT=5000

# For local dev: http://localhost:5173
# For production: https://p-robe.vercel.app
CLIENT_URL=http://localhost:5173
